# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_SITE_URL=https://edinio.com
NEXT_PUBLIC_APP_URL=https://edinio.com

# Marketing — pixeli platforma (edinio.com insasi, NU magazinele clientilor)
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_ULTRA=price_...

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@edinio.com
EMAIL_FROM=Edinio <noreply@edinio.com>
SUPPORT_ADMIN_EMAIL=support@edinio.com

# SmartBill (Facturare)
SMARTBILL_EMAIL=
SMARTBILL_TOKEN=
SMARTBILL_CIF=
SMARTBILL_SERIES=

# Upload Temp (secure random string)
UPLOAD_TEMP_SECRET=change-me-to-random-string

# Vercel Cron (auto-set by Vercel, or set manually for local testing)
CRON_SECRET=

# Cloudflare R2 (Image Storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=edinio-uploads
# Public base used when SAVING object URLs. Either the raw bucket domain
# (https://pub-XXXXX.r2.dev) or the CDN custom domain (https://edinio-cdn.com).
# Switching to the CDN domain is safe: old r2.dev URLs are still recognized.
R2_PUBLIC_URL=https://pub-XXXXX.r2.dev

# Optional CDN custom domain bound to the R2 bucket, with Cloudflare Image
# Transformations enabled. When set, images RENDER through the edge resizer
# (<cdn>/cdn-cgi/image/...) instead of the self-hosted /api/img optimizer.
# Existing *.r2.dev URLs are rewritten to this domain at render time (no migration).
NEXT_PUBLIC_CDN_URL=https://edinio-cdn.com

# Reseller.ro (Domenii)
RESELLER_EMAIL=
RESELLER_API_KEY=
RESELLER_NS1=ns1.domaincity.ro
RESELLER_NS2=ns2.domaincity.ro
